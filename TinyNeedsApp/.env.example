# Copy to .env and fill in real values (never commit .env).
# EXPO_PUBLIC_* vars are bundled into the client app - never put secret keys here.

# Supabase Dashboard -> Project Settings -> API
EXPO_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# Stripe Dashboard -> Developers -> API keys (the PUBLISHABLE key only, starts with pk_)
EXPO_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your-publishable-key
